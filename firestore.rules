rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: owner writes; any authenticated user can read (needed for friend lookups)
    match /profiles/{profileId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // Entries (stories): owner writes and updates; any authenticated user reads
    match /entries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // Friend connections: any authenticated user can read/create;
    // update/delete require ownership of one of the two profiles in the connection.
    match /friendConnections/{connId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        (get(/databases/$(database)/documents/profiles/$(request.resource.data.profileIds[0])).data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/profiles/$(request.resource.data.profileIds[1])).data.userId == request.auth.uid);
      allow update, delete: if request.auth != null &&
        (get(/databases/$(database)/documents/profiles/$(resource.data.profileIds[0])).data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/profiles/$(resource.data.profileIds[1])).data.userId == request.auth.uid);
    }

    // Invites: any authenticated user can read/create/delete (delete needed for acceptInvite)
    // Updates are disallowed to prevent tampering
    match /invites/{code} {
      allow read, create, delete: if request.auth != null;
      allow update: if false;
    }

    // User settings: owner only
    match /userSettings/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
  }
}
